# Server Configuration
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/veda-ai

# Redis Configuration (Optional - falls back to In-Memory Queue if not available)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# OpenRouter API Key for AI Generation (Optional - falls back to procedural generation if not set)
OPENROUTER_API_KEY=your_openrouter_api_key_here
